# Copy this file to .env and fill in your values.
# In production, secrets are injected via GCP Secret Manager (see terraform/).

# Database
DATABASE_URL=postgresql://relops:relops@localhost:5432/relops

# SimpleMDM
SIMPLEMDM_API_KEY=

# Taskcluster (leave blank for unauthenticated access to public pools)
TC_ROOT_URL=https://firefox-ci-tc.services.mozilla.com
TC_CLIENT_ID=
TC_ACCESS_TOKEN=

# Google Sheets
GOOGLE_SHEETS_ID=                  # ID of existing master sheet (read-only)
GOOGLE_EXPORT_SHEET_ID=            # ID of sheet the dashboard writes to
GOOGLE_CREDENTIALS_JSON=/app/credentials.json   # path to service account key

# Puppet repo (public GitHub, no auth needed)
PUPPET_REPO_URL=https://github.com/mozilla-platform-ops/ronin_puppet
PUPPET_REPO_PATH=/tmp/ronin_puppet

# Sync intervals (seconds)
SYNC_INTERVAL_TC=300
SYNC_INTERVAL_SIMPLEMDM=900
SYNC_INTERVAL_SHEETS=1800
SYNC_INTERVAL_PUPPET=3600

# Alert thresholds
TC_MISSING_THRESHOLD_HOURS=24

# Security
# Comma-separated CORS origins. Use "*" for local dev only.
# In production, set to your actual domain: https://hangar.relops.mozilla.com
CORS_ORIGINS=*

# SSH known_hosts for worker terminal connections.
# In production this is mounted from Secret Manager (see terraform/secrets.tf).
# For local dev, set SSH_INSECURE_SKIP_HOST_CHECK=true to skip host key checking.
# To generate known_hosts for the fleet:
#   ssh-keyscan -H macmini-r8-{100..200}.test.releng.mdc1.mozilla.com >> known_hosts
SSH_KNOWN_HOSTS_PATH=/run/secrets/ssh_known_hosts
SSH_INSECURE_SKIP_HOST_CHECK=false

# Logging: set to true in production for Cloud Logging structured JSON output.
LOG_JSON=false

# Frontend static files directory (leave blank for auto-detection)
STATIC_DIR=
